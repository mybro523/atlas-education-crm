# ─────────────────────────────────────────────────────────────
# Atlas CRM — ROOT .env.example
# Copy to `.env` (in this same root directory) before running
# `docker compose up`. These values feed the docker-compose
# postgres & redis services.
#
# NOTE: backend/ and frontend/ have their OWN .env.example files
# with app-specific variables (DATABASE_URL, JWT secrets,
# VITE_API_URL, etc.). This root file only configures the local
# infrastructure containers.
# ─────────────────────────────────────────────────────────────

# ---- PostgreSQL (used by the `postgres` compose service) ----
POSTGRES_USER=atlas
POSTGRES_PASSWORD=atlas_dev_password
POSTGRES_DB=atlas_crm
# Host port that maps to the container's 5432
POSTGRES_PORT=5432

# ---- Redis (used by the `redis` compose service) ----
REDIS_HOST=localhost
REDIS_PORT=6379

# ---- Convenience: connection string for backend/.env ----
# When using the docker-compose Postgres, the backend can connect via:
# DATABASE_URL="postgresql://atlas:atlas_dev_password@localhost:5432/atlas_crm?schema=public"
