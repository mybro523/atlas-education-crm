# ─────────────────────────────────────────────
# Atlas CRM — root .gitignore (Node/Nest + Vite)
# ─────────────────────────────────────────────

# Dependencies
node_modules/
.pnp/
.pnp.js
.yarn/

# Build output
dist/
build/
out/
.output/

# NestJS
*.tsbuildinfo

# Vite / frontend
.vite/
frontend/dist/
frontend/build/

# Environment files (never commit secrets)
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Test / coverage
coverage/
.nyc_output/

# Prisma (generated client is regenerated; keep schema/migrations)
# backend/node_modules/.prisma is covered by node_modules above

# Editor / IDE
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Docker volumes (if any local bind mounts get created)
.docker-data/

# Misc caches
.cache/
.temp/
.tmp/
*.pid
*.seed
*.pid.lock
